   "source": [
    "#plot y=x**1/2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "x=np.linspace(0,100,100_000)\n",
    "y=np.sqrt(x)\n",
    "\n",
    "plt.plot(x,y,label=\"y=x**1/2\")\n",
    "plt.xlabel(\"x\")\n",
    "plt.ylabel(\"y\")\n",
    "plt.title(\"Graph of y = x^(1/2)\")\n",
    "plt.legend()\n",
    "plt.show()\n"
   ]
  }
