# Data Cleaning


#missing value


df=pd.read_csv("raw_data.csv")
df


df.isnull()


df.isna()# same same but diffe


df.isnull().sum() #count how many missing val


df.dropna(axis=1)# drop entire row 


df.fillna(0)# fill missing val with 0


df.fillna("Badmoss")


cleaned=df.copy()
age_mean=cleaned["age"].mean()
cleaned["age"]=cleaned["age"].fillna(age_mean.round())


cleaned


df.ffill()#forward fill


df.bfill()


df


