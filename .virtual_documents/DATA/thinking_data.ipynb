import json


#load the data
def load_data(filename):
    with open(filename,"r")as f:
        data=json.load(f)
    return data



data=load_data("store_data.json")
print(data)
print(type(data))


#clean and structure the data
def clean_data(data):
    text_to_num={"one":1,"two":2,"three":3,"four":4,"five":5}
    cleaned_data=[]
    unique_users=set()
    for user in data:
        raw_data=str(user["rating"].strip().lower())
        if raw_data in text_to_num:
            raw_data=text_to_num[raw_data]
        user["rating"]=raw_data

        #handle misiing value
        raw_age=user.get("age")
        if(raw_age==None):
            user["age"]=None

        #deduplication
        if(user["name"].strip() in unique_users):
            continue
        cleaned_data.append(user)
    return cleaned_data


clean_data(data)
